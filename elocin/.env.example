PORT=3000
DATABASE_URL=postgres://user:password@localhost:5432/elocin
JWT_SECRET=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173

# Email (password reset). Optional in development — without these the app runs
# in SAMPLE MODE and logs the reset link instead of sending it. REQUIRED in
# production (boot fails if missing): RESEND_API_KEY, FROM_EMAIL, FRONTEND_URL.
RESEND_API_KEY=
FROM_EMAIL=Elocin <no-reply@yourdomain.com>

# External AI (offline lexicon proposer + any future AI feature). ALL external
# AI is OFF by default (privacy by default). To enable, BOTH are required:
#   EXTERNAL_AI_ENABLED=true   — global kill switch (default off)
#   ANTHROPIC_API_KEY=...      — provider key
# AND the organization must opt in (organizations.external_processing_allowed).
# Every request routes through lib/externalAI.js: de-identified, fail-closed on
# residual PII, audited (no raw prompt logged). See docs/privacy_external_ai.md.
EXTERNAL_AI_ENABLED=false
ANTHROPIC_API_KEY=
